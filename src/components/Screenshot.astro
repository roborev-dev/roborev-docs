---
interface Props {
  src: string;
  alt: string;
  maxWidth?: string;
}

const { src, alt, maxWidth } = Astro.props;
const imgStyle = maxWidth ? `max-width: ${maxWidth}` : undefined;
---

<figure class="screenshot" data-lightbox>
  <img src={src} alt={alt} loading="lazy" style={imgStyle} />
</figure>

<style>
  .screenshot {
    margin: 1rem 0;
    cursor: zoom-in;
  }

  .screenshot img {
    width: 100%;
    max-width: 800px;
    border-radius: 6px;
    display: block;
  }
</style>
